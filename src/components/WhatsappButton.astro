---
const {t} = Astro.props;
---

<!-- zalo FLOATING BUTTON -->
<a
  href="https://zalo.me/84283456789"
  target="_blank"
  rel="noopener noreferrer"
  class="zalo-fab"
  aria-label={t('zalo.tooltip')}
>
  <style>
    .zalo-fab {
      position: fixed;
      bottom: 30px;
      right: 30px;
      z-index: 999;
      width: 58px;
      height: 58px;
      background: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 6px 24px rgba(255,255,255,0.45);
      transition: all 0.3s ease;
      animation: pulse-wa 2.5s infinite;
    }

    .zalo-fab:hover {
      transform: scale(1.1);
      box-shadow: 0 8px 32px rgba(37,211,102,0.6);
    }

    .zalo-fab svg {
      width: 30px;
      height: 30px;
      fill: white;
    }

    .zalo-fab .wa-tooltip {
      position: absolute;
      right: calc(100% + 12px);
      top: 50%;
      transform: translateY(-50%);
      background: #1A2332;
      color: white;
      padding: 7px 14px;
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.8rem;
      white-space: nowrap;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease;
    }

    .zalo-fab .wa-tooltip::after {
      content: '';
      position: absolute;
      left: 100%;
      top: 50%;
      transform: translateY(-50%);
      border: 6px solid transparent;
      border-left-color: #1A2332;
    }

    .zalo-fab:hover .wa-tooltip {
      opacity: 1;
    }

    @keyframes pulse-wa {
      0%, 100% { box-shadow: 0 6px 24px rgba(37, 106, 211, 0.45); }
      50% { box-shadow: 0 6px 36px rgba(37, 78, 211, 0.7), 0 0 0 8px rgba(37,211,102,0.12); }
    }
  </style>

<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" class="h-5 w-5" aria-label="Zalo">
  <circle cx="12" cy="12" r="10" fill="#0068FF"/>
  <path
    d="M6.7 8.1h4.4L7.8 15.9H5.9l2.3-5.6H6.1l.6-2.2Zm5.1 0h1.8l1.3 3 1.2-3h1.8l-3.2 7.8h-1.3l-1.9-4.6-.8 4.6H9.9l1.9-7.8Z"
    fill="white"
  />
</svg>
  <span class="wa-tooltip">{t('zalo.tooltip')}</span>
</a>