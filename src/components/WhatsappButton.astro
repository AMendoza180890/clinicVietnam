---
const { t } = Astro.props;
---

<!-- zalo FLOATING BUTTON -->
<a
  href="https://zalo.me/84283456789"
  target="_blank"
  rel="noopener noreferrer"
  class="zalo-fab"
  aria-label={t("zalo.tooltip")}
>
  <style>
    .zalo-fab {
      position: fixed;
      bottom: 30px;
      right: 30px;
      z-index: 999;
      width: 58px;
      height: 58px;
      background: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 6px 24px rgba(255, 255, 255, 0.45);
      transition: all 0.3s ease;
      animation: pulse-wa 2.5s infinite;
    }

    .zalo-fab:hover {
      transform: scale(1.1);
      box-shadow: 0 8px 32px rgba(37, 98, 211, 0.6);
    }

    .zalo-fab svg {
      width: 30px;
      height: 30px;
      fill: white;
    }

    .zalo-fab .wa-tooltip {
      position: absolute;
      right: calc(100% + 12px);
      top: 50%;
      transform: translateY(-50%);
      background: #1a2332;
      color: white;
      padding: 7px 14px;
      border-radius: 8px;
      font-family: "DM Sans", sans-serif;
      font-size: 0.8rem;
      white-space: nowrap;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease;
    }

    .zalo-fab .wa-tooltip::after {
      content: "";
      position: absolute;
      left: 100%;
      top: 50%;
      transform: translateY(-50%);
      border: 6px solid transparent;
      border-left-color: #1a2332;
    }

    .zalo-fab:hover .wa-tooltip {
      opacity: 1;
    }

    @keyframes pulse-wa {
      0%,
      100% {
        box-shadow: 0 6px 24px rgba(37, 106, 211, 0.45);
      }
      50% {
        box-shadow:
          0 6px 36px rgba(37, 78, 211, 0.7),
          0 0 0 8px rgba(37, 211, 102, 0.12);
      }
    }
  </style>
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><title>Zalo SVG Icon</title><path fill="#0000ff" d="M12.49 10.272v-.45h1.347v6.322h-.77a.576.576 0 0 1-.577-.573v.001a3.27 3.27 0 0 1-1.938.632a3.284 3.284 0 0 1-3.284-3.282a3.284 3.284 0 0 1 3.284-3.282a3.27 3.27 0 0 1 1.937.632zM6.919 7.79v.205c0 .382-.051.694-.3 1.06l-.03.034a8 8 0 0 0-.242.285L2.024 14.8h4.895v.768a.576.576 0 0 1-.577.576H0v-.362c0-.443.11-.641.25-.847L4.858 9.23H.192V7.79zm8.551 8.354a.48.48 0 0 1-.48-.48V7.79h1.441v8.354zM20.693 9.6a3.306 3.306 0 1 1 .002 6.612a3.306 3.306 0 0 1-.002-6.612m-10.14 5.253a1.932 1.932 0 1 0 0-3.863a1.932 1.932 0 0 0 0 3.863m10.14-.003a1.945 1.945 0 1 0 0-3.89a1.945 1.945 0 0 0 0 3.89"/></svg>
  <span class="wa-tooltip">{t("zalo.tooltip")}</span>
</a>
