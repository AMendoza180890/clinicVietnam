---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/translations.js';

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const doctors = [
  {
    name: 'Dr. Sarah Chen',
    specialty: t('services.cardiology.title'),
    dept: 'cardiology',
    education: 'Harvard Medical School',
    experience: '15 years',
    img: 'https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=400&h=400&fit=crop&crop=face',
    rating: 4.9,
    reviews: 312,
  },
  {
    name: 'Dr. James Park',
    specialty: t('services.neurology.title'),
    dept: 'neurology',
    education: 'Johns Hopkins University',
    experience: '18 years',
    img: 'https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=400&h=400&fit=crop&crop=face',
    rating: 4.8,
    reviews: 287,
  },
  {
    name: 'Dr. Linh Nguyen',
    specialty: t('services.pediatrics.title'),
    dept: 'pediatrics',
    education: 'University of Melbourne',
    experience: '12 years',
    img: 'https://images.unsplash.com/photo-1594824476967-48c8b964273f?w=400&h=400&fit=crop&crop=face',
    rating: 4.9,
    reviews: 445,
  },
  {
    name: 'Dr. Michael Torres',
    specialty: t('services.orthopedics.title'),
    dept: 'orthopedics',
    education: 'Stanford University',
    experience: '20 years',
    img: 'https://images.unsplash.com/photo-1622253692010-333f2da6031d?w=400&h=400&fit=crop&crop=face',
    rating: 4.7,
    reviews: 198,
  },
  {
    name: 'Dr. Ji-Young Kim',
    specialty: t('services.cardiology.title'),
    dept: 'cardiology',
    education: 'Seoul National University',
    experience: '14 years',
    img: 'https://images.unsplash.com/photo-1651008376811-b90baee60c1f?w=400&h=400&fit=crop&crop=face',
    rating: 4.8,
    reviews: 267,
  },
  {
    name: 'Dr. Anh Tran',
    specialty: t('services.neurology.title'),
    dept: 'neurology',
    education: 'Paris Descartes University',
    experience: '10 years',
    img: 'https://images.unsplash.com/photo-1582750433449-648ed127bb54?w=400&h=400&fit=crop&crop=face',
    rating: 4.6,
    reviews: 156,
  },
];
---

<Layout lang={lang} title={t('nav.doctors')}>

  <!-- HERO -->
  <section class="page-hero section">
    <div class="hero-pattern"></div>
    <div class="container">
      <div class="page-hero-content">
        <span class="tag">{t('nav.doctors')}</span>
        <h1 class="section-title">{t('doctors.hero.title')}</h1>
        <p class="section-desc">{t('doctors.hero.desc')}</p>
      </div>
    </div>
  </section>

  <!-- DOCTORS GRID -->
  <section class="section doctors-main-section">
    <div class="container">
      <!-- Filter Tabs -->
      <div class="filter-tabs" id="filterTabs">
        {['all', 'cardiology', 'neurology', 'pediatrics', 'orthopedics'].map(f => (
          <button
            class={`filter-btn ${f === 'all' ? 'active' : ''}`}
            data-filter={f}
          >
            {t(`doctors.filter.${f}`)}
          </button>
        ))}
      </div>

      <!-- Doctors Grid -->
      <div class="doctors-grid" id="doctorsGrid">
        {doctors.map(doc => (
          <div class="doctor-card-full card" data-dept={doc.dept}>
            <div class="dcf-img-wrap">
              <img src={doc.img} alt={doc.name} loading="lazy" />
              <div class="dcf-dept">{doc.specialty}</div>
            </div>
            <div class="dcf-body">
              <div class="dcf-header">
                <h3 class="dcf-name">{doc.name}</h3>
                <div class="dcf-rating">
                  <span class="star">⭐</span>
                  <span class="rating-num">{doc.rating}</span>
                  <span class="rating-count">({doc.reviews})</span>
                </div>
              </div>
              <div class="dcf-meta">
                <div class="dcf-meta-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z"/></svg>
                  {doc.education}
                </div>
                <div class="dcf-meta-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
                  {doc.experience}
                </div>
              </div>
              <a href={`/${lang}/contact`} class="btn btn-primary" style="width: 100%; justify-content: center;">
                {t('home.hero.cta')}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS SECTION -->
  <section class="section team-stats-section">
    <div class="container">
      <div class="team-stats">
        {[
          { icon: '👩‍⚕️', num: '80+', label: lang === 'vi' ? 'Bác Sĩ Chuyên Khoa' : lang === 'ko' ? '전문 의사' : 'Specialist Doctors' },
          { icon: '🎓', num: '15+', label: lang === 'vi' ? 'Quốc Tịch' : lang === 'ko' ? '국적' : 'Nationalities' },
          { icon: '🏅', num: '95%', label: lang === 'vi' ? 'Hài Lòng Bệnh Nhân' : lang === 'ko' ? '환자 만족도' : 'Patient Satisfaction' },
          { icon: '🌏', num: '12+', label: lang === 'vi' ? 'Chuyên Khoa' : lang === 'ko' ? '전문 분야' : 'Specialties' },
        ].map(s => (
          <div class="ts-item">
            <div class="ts-icon">{s.icon}</div>
            <div class="ts-num">{s.num}</div>
            <div class="ts-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- JOIN SECTION -->
  <section class="section join-section">
    <div class="container">
      <div class="join-box">
        <div class="join-icon">🏥</div>
        <h2 class="join-title">{t('doctors.join.title')}</h2>
        <p class="join-desc">{t('doctors.join.desc')}</p>
        <a href={`/${lang}/contact`} class="btn btn-primary btn-lg">{t('doctors.join.btn')}</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #f0f9f9 0%, #e8f4f8 100%);
    position: relative;
    overflow: hidden;
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 2px 2px, rgba(10,110,110,0.06) 1px, transparent 0);
    background-size: 36px 36px;
  }

  .page-hero-content { position: relative; z-index: 1; max-width: 600px; }

  /* FILTER */
  .doctors-main-section { background: var(--bg); }

  .filter-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 10px 22px;
    border-radius: 100px;
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    border: 2px solid var(--border);
    background: white;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }

  /* DOCTORS GRID */
  .doctors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .doctor-card-full { padding: 0; overflow: hidden; }

  .dcf-img-wrap {
    position: relative;
    overflow: hidden;
  }

  .dcf-img-wrap img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    object-position: top;
    transition: transform 0.4s ease;
  }

  .doctor-card-full:hover .dcf-img-wrap img { transform: scale(1.05); }

  .dcf-dept {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(6,79,79,0.92));
    color: white;
    padding: 24px 20px 12px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .dcf-body { padding: 20px 24px; }

  .dcf-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
    gap: 8px;
  }

  .dcf-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
  }

  .dcf-rating {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .star { font-size: 0.75rem; }
  .rating-num { font-weight: 700; color: var(--text); }
  .rating-count { color: var(--text-muted); }

  .dcf-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 18px;
  }

  .dcf-meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .dcf-meta-item svg { color: var(--primary); flex-shrink: 0; }

  .doctor-card-full.hidden { display: none; }

  /* TEAM STATS */
  .team-stats-section { background: linear-gradient(135deg, var(--primary-dark), var(--primary)); }

  .team-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .ts-item {
    text-align: center;
    padding: 48px 24px;
    border-right: 1px solid rgba(255,255,255,0.12);
  }

  .ts-item:last-child { border: none; }
  .ts-icon { font-size: 2rem; margin-bottom: 12px; }
  .ts-num { font-family: 'Syne', sans-serif; font-size: 2.5rem; font-weight: 800; color: white; }
  .ts-label { font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-top: 6px; }

  /* JOIN */
  .join-section { background: white; }

  .join-box {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .join-icon { font-size: 3rem; }
  .join-title { font-size: clamp(1.5rem, 3vw, 2rem); }
  .join-desc { color: var(--text-muted); line-height: 1.7; }

  .btn-lg { padding: 16px 32px; font-size: 1rem; }

  @media (max-width: 1024px) {
    .doctors-grid { grid-template-columns: repeat(2, 1fr); }
    .team-stats { grid-template-columns: repeat(2, 1fr); }
    .ts-item:nth-child(2) { border-right: none; }
    .ts-item:nth-child(3) { border-right: 1px solid rgba(255,255,255,0.12); }
    .ts-item:nth-child(3),
    .ts-item:nth-child(4) { border-top: 1px solid rgba(255,255,255,0.12); }
  }

  @media (max-width: 640px) {
    .doctors-grid { grid-template-columns: 1fr; }
    .team-stats { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const doctorCards = document.querySelectorAll('.doctor-card-full');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.getAttribute('data-filter');

      doctorCards.forEach(card => {
        if (filter === 'all' || card.getAttribute('data-dept') === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
