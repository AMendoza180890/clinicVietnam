---
import { useTranslations } from "../i18n/translations.js";
import Logo from "../assets/logo/logo3.png";
import { Image } from "astro:assets";
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<!-- FOOTER -->
<footer id="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <div class="logo">
          <div class="logo-ico">
            <Image src={Logo} alt="Phong Kham SC" />
            <!-- <svg viewBox="0 0 24 24"
              ><path
                d="M19 3H5C3.9 3 3 3.9 3 5v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L12 14.17l7.59-7.59L21 8l-9 9z"
              ></path></svg
            > -->
          </div>
          <div class="logo-text">Phong <span>Kham</span></div>
        </div>
        <p class="footer-tagline">{t("footer.tagline")}</p>
        <div class="social-links">
          <!-- Facebook -->
          <a href="#" class="social-link" aria-label="Facebook">
            <svg viewBox="0 0 24 24"
              ><path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path></svg
            >
          </a>
          <!-- Instagram -->
          <a href="#" class="social-link" aria-label="Instagram">
            <svg viewBox="0 0 24 24"
              ><path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
              ></path></svg
            >
          </a>
          <!-- Twitter/X -->
          <a href="#" class="social-link" aria-label="Twitter">
            <svg viewBox="0 0 24 24"
              ><path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path></svg
            >
          </a>
          <!-- YouTube -->
          <a href="#" class="social-link" aria-label="YouTube">
            <svg viewBox="0 0 24 24"
              ><path
                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
              ></path></svg
            >
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-col">
        <h4>{t("footer.quick")}</h4>
        <ul class="footer-links">
          <li><a href={`/${lang}/`}>{t("nav.home")}</a></li>
          <li><a href={`/${lang}/services`}>{t("nav.services")}</a></li>
          <li><a href={`/${lang}/doctors`}>{t("nav.doctors")}</a></li>
          <li><a href={`/${lang}/dental`}>{t("nav.dental")}</a></li>
          <li><a href={`/${lang}/contact`}>{t("nav.contact")}</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h4>{t("footer.services")}</h4>
        <ul class="footer-links">
          <li>
            <a href={`/${lang}/services`}>{t("services.cardiology.title")}</a>
          </li>
          <li>
            <a href={`/${lang}/services`}>{t("services.neurology.title")}</a>
          </li>
          <li>
            <a href={`/${lang}/services`}>{t("services.pediatrics.title")}</a>
          </li>
          <li>
            <a href={`/${lang}/services`}>{t("services.orthopedics.title")}</a>
          </li>
          <li>
            <a href={`/${lang}/services`}>{t("services.dermatology.title")}</a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="footer-col">
        <h4>{t("contact.info.title")}</h4>

        <div class="footer-contact-item">
          <div class="footer-contact-icon">
            <svg viewBox="0 0 24 24"
              ><path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
              ></path></svg
            >
          </div>
          <div class="footer-contact-info">
            <p>{t("contact.info.address")}</p>
            <a href="https://maps.app.goo.gl/9kR6GDaaiAzgZBQ76" target="_blank">
              <span>{t("footer.address")}</span>
            </a>
          </div>
        </div>

        <div class="footer-contact-item">
          <div class="footer-contact-icon">
            <svg viewBox="0 0 24 24"
              ><path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
              ></path></svg
            >
          </div>
          <div class="footer-contact-info">
            <p>{t("contact.info.addressDental")}</p>
            <a href="https://maps.app.goo.gl/1GaqyckqXwXDLzxb7" target="_blank">
              <span>{t("footer.addressDental")}</span>
            </a>
          </div>
        </div>


        <div class="footer-contact-item">
          <div class="footer-contact-icon">
            <svg viewBox="0 0 24 24"
              ><path
                d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
              ></path></svg
            >
          </div>
          <div class="footer-contact-info">
            <p>{t("contact.info.phone")}</p>
            <a href=`tel:+${t("footer.phone")}`>
              <span>{t("footer.phone")}</span>
            </a>
          </div>
        </div>

        <div class="footer-contact-item">
          <div class="footer-contact-icon">
            <svg viewBox="0 0 24 24"
              ><path
                d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
              ></path></svg
            >
          </div>
          <div class="footer-contact-info">
            <p>{t("contact.info.email")}</p>
            <a href="mailto:info@phongkham.com">
              <span>info@phongkham.com</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="footer-copyright">{t("footer.copyright")}</p>
      <div class="footer-bottom-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  #site-footer {
    background: linear-gradient(135deg, #0a1a2a 0%, #0d2535 100%);
    color: #cbd5e0;
    padding: 70px 0 0;
    margin-top: var(--section-gap);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-brand .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: "Open Sans", sans-serif;
    font-weight: 800;
    font-size: 1.3rem;
    color: white;
    margin-bottom: 16px;
  }

  .footer-brand .logo-ico {
    width: 38px;
    height: 38px;
    /* background: linear-gradient(135deg, var(--primary), var(--primary-light)); */
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-brand .logo-ico svg {
    width: 20px;
    height: 20px;
    fill: white;
  }
  .footer-brand .logo span {
    color: var(--accent);
  }

  .footer-tagline {
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 24px;
    color: #94a3b8;
  }

  .social-links {
    display: flex;
    gap: 10px;
  }

  .social-link {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
    color: #94a3b8;
  }

  .social-link:hover {
    background: var(--primary);
    border-color: var(--primary);
    color: white;
    transform: translateY(-3px);
  }

  .social-link svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .footer-col h4 {
    font-family: "Open Sans", sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: white;
    margin-bottom: 20px;
    letter-spacing: 0.05em;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: #94a3b8;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .footer-links a::before {
    content: "→";
    font-size: 0.75rem;
    color: var(--primary-light);
  }

  .footer-links a:hover {
    color: white;
  }

  .footer-contact-item {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
  }

  .footer-contact-icon {
    width: 36px;
    height: 36px;
    background: rgba(10, 110, 110, 0.2);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .footer-contact-icon svg {
    width: 16px;
    height: 16px;
    fill: var(--accent);
  }

  .footer-contact-info p {
    font-size: 0.8rem;
    color: #64748b;
    margin-bottom: 2px;
    font-family: "Open Sans", sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-contact-info span {
    font-size: 0.875rem;
    color: #94a3b8;
  }

  .footer-bottom {
    padding: 20px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .footer-copyright {
    font-size: 0.8rem;
    color: #4a5568;
  }

  .footer-bottom-links {
    display: flex;
    gap: 24px;
  }

  .footer-bottom-links a {
    font-size: 0.8rem;
    color: #4a5568;
    transition: color 0.2s ease;
  }

  .footer-bottom-links a:hover {
    color: #94a3b8;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
