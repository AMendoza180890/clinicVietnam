---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/translations.js';
import Hero from '../components/Hero.astro';
import Flag from '../components/Flag.astro';

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const services = [
  { key: 'cardiology', icon: '🫀', color: '#FF6B6B', bg: '#FF6B6B15' },
  { key: 'neurology', icon: '🧠', color: '#4ECDC4', bg: '#4ECDC415' },
  { key: 'pediatrics', icon: '👶', color: '#45B7D1', bg: '#45B7D115' },
  { key: 'orthopedics', icon: '🦴', color: '#96CEB4', bg: '#96CEB415' },
  { key: 'dermatology', icon: '✨', color: '#FFEAA7', bg: '#FFEAA720' },
  { key: 'oncology', icon: '🎗️', color: '#DDA0DD', bg: '#DDA0DD15' },
];

const processSteps = [
  { num: '01', key: 'step1', icon: '📅' },
  { num: '02', key: 'step2', icon: '💬' },
  { num: '03', key: 'step3', icon: '🔬' },
  { num: '04', key: 'step4', icon: '💊' },
];
---

<Layout lang={lang} title={t('nav.services')} descripton={t('services.description')}>

  <!-- HERO -->
  <Hero tag={t('nav.services')} title={t('services.hero.title')} description={t('services.hero.desc')} />

  <!-- SERVICES LIST -->
  <section class="section services-list-section">
    <div class="container">
      <div class="section-header">
        <Flag title={t('services.list.title')}/>
      </div>
      <div class="services-grid">
        {services.map(svc => (
          <div class="svc-card card">
            <div class="svc-card-header">
              <div class="svc-icon-box" style={`background: ${svc.bg}; border: 2px solid ${svc.color}30;`}>
                <span>{svc.icon}</span>
              </div>
              <div class="svc-card-badge">Available</div>
            </div>
            <h3 class="svc-card-title">{t(`services.${svc.key}.title`)}</h3>
            <p class="svc-card-desc">{t(`services.${svc.key}.desc`)}</p>
            <a href={`/${lang}/contact`} class="svc-card-cta">
              {t('home.hero.cta')}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS SECTION -->
  <section class="section process-section">
    <div class="container">
      <div class="section-header text-center">
        <Flag title={t('services.process.title')} />
        <h2 class="section-title">{t('services.process.title')}</h2>
      </div>
      <div class="process-grid">
        {processSteps.map((step, i) => (
          <div class="process-step">
            <div class="process-num">{step.num}</div>
            <div class="process-icon">{step.icon}</div>
            <h3 class="process-title">{t(`services.process.${step.key}`)}</h3>
            <p class="process-desc">{t(`services.process.${step.key}.desc`)}</p>
            {i < processSteps.length - 1 && <div class="process-arrow">→</div>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY US SECTION -->
  <section class="section why-section">
    <div class="container">
      <div class="why-grid">
        <div class="why-content">
          <Flag title="Why MediCare" />
          <h2 class="section-title">
            {lang === 'vi' ? 'Tại Sao Chọn Chúng Tôi?' : lang === 'ko' ? '왜 우리를 선택해야 하나요?' : 'Why Choose MediCare?'}
          </h2>
          <div class="why-items">
            {[
              { icon: '🏅', title: lang === 'vi' ? 'Đẳng Cấp Thế Giới' : lang === 'ko' ? '세계적 수준' : 'World-Class Standards', desc: lang === 'vi' ? 'Được công nhận bởi các tổ chức y tế quốc tế.' : lang === 'ko' ? '국제 의료 기관의 인증.' : 'Recognized by international healthcare bodies.' },
              { icon: '⚡', title: lang === 'vi' ? 'Kết Quả Nhanh Chóng' : lang === 'ko' ? '빠른 결과' : 'Fast Results', desc: lang === 'vi' ? 'Kết quả xét nghiệm nhanh chóng, chính xác.' : lang === 'ko' ? '빠르고 정확한 검사 결과.' : 'Quick turnaround on test results and diagnoses.' },
              { icon: '💙', title: lang === 'vi' ? 'Chăm Sóc Tận Tình' : lang === 'ko' ? '헌신적 케어' : 'Compassionate Care', desc: lang === 'vi' ? 'Đội ngũ y tế luôn đặt bệnh nhân lên hàng đầu.' : lang === 'ko' ? '항상 환자를 최우선으로 하는 의료팀.' : 'Medical team that always puts patients first.' },
              { icon: '🌐', title: lang === 'vi' ? 'Đa Ngôn Ngữ' : lang === 'ko' ? '다국어 서비스' : 'Multilingual', desc: lang === 'vi' ? 'Phục vụ bằng tiếng Việt, tiếng Anh và tiếng Hàn.' : lang === 'ko' ? '베트남어, 영어, 한국어 서비스.' : 'Services in Vietnamese, English, and Korean.' },
            ].map(item => (
              <div class="why-item">
                <div class="why-icon">{item.icon}</div>
                <div>
                  <h4 class="why-title">{item.title}</h4>
                  <p class="why-desc">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="why-visual">
          <img src="/src/assets/image/img2.JPG" alt="Medical Equipment" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="section cta-banner-section">
    <div class="container">
      <div class="cta-banner">
        <div class="cta-banner-content">
          <h2 class="cta-banner-title">{t('services.cta.title')}</h2>
          <p class="cta-banner-desc">
            {lang === 'vi' ? 'Liên hệ ngay để được tư vấn miễn phí.' : lang === 'ko' ? '무료 상담을 위해 지금 연락하세요.' : 'Contact us now for a free consultation.'}
          </p>
        </div>
        <a href={`/${lang}/contact`} class="btn btn-accent btn-lg">{t('services.cta.btn')}</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .page-hero {
    background: linear-gradient(135deg, #f0f9f9 0%, #e8f4f8 100%);
    position: relative;
    overflow: hidden;
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 2px 2px, rgba(10,110,110,0.06) 1px, transparent 0);
    background-size: 36px 36px;
  }

  .page-hero-content {
    max-width: 640px;
    position: relative;
    z-index: 1;
  }

  .hero-title { margin-top: 12px; }

  /* SERVICES GRID */
  .services-list-section { background: white; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .svc-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
  }

  .svc-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .svc-icon-box {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
  }

  .svc-card-badge {
    font-family: 'Syne', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #22C55E;
    background: #22C55E15;
    padding: 4px 10px;
    border-radius: 100px;
  }

  .svc-card-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }

  .svc-card-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
    flex: 1;
  }

  .svc-card-cta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: gap 0.2s ease;
    margin-top: 8px;
  }

  .svc-card-cta:hover { gap: 10px; }

  /* PROCESS */
  .process-section { background: var(--bg); }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }

  .process-step {
    text-align: center;
    padding: 32px 24px;
    background: white;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    position: relative;
    margin: 0 8px;
    transition: all 0.3s ease;
  }

  .process-step:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary);
  }

  .process-num {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 3rem;
    color: rgba(10,110,110,0.08);
    line-height: 1;
    margin-bottom: -8px;
  }

  .process-icon { font-size: 2.5rem; margin-bottom: 12px; }

  .process-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--text);
  }

  .process-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .process-arrow {
    position: absolute;
    top: 50%;
    right: -20px;
    transform: translateY(-50%);
    font-size: 1.5rem;
    color: var(--primary-light);
    z-index: 10;
    font-weight: 700;
  }

  /* WHY US */
  .why-section { background: white; }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .why-items {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 32px;
  }

  .why-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .why-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    border-radius: 12px;
  }

  .why-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
  }

  .why-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .why-visual img {
    width: 100%;
    height: 480px;
    object-fit: cover;
    border-radius: 20px;
    box-shadow: var(--shadow-lg);
  }

  /* CTA BANNER */
  .cta-banner-section { background: var(--primary); }

  .cta-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .cta-banner-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: white;
    margin-bottom: 8px;
  }

  .cta-banner-desc {
    color: rgba(255,255,255,0.7);
    font-size: 1rem;
  }

  .text-center { text-align: center; }
  .section-header { margin-bottom: 48px; }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .process-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .process-arrow { display: none; }
    .process-step { margin: 0; }
    .why-grid { grid-template-columns: 1fr; }
    .why-visual { display: none; }
  }

  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
    .cta-banner { flex-direction: column; text-align: center; }
  }
</style>
