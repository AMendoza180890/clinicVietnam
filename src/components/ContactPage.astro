---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/translations.js';
import Hero from '../components/Hero.astro';
import Flag from '../components/Flag.astro';

const { lang = import.meta.env.LANG } = Astro.props;
const Email = import.meta.env.EMAIL;
const t = useTranslations(lang);
---

<Layout lang={lang} title={t('nav.contact')} description={t('contact.description')}>

  <!-- HERO -->
  <Hero tag={t('nav.contact')} title={t('contact.hero.title')} description={t('contact.hero.desc')} />
  <!-- <section class="page-hero section">
    <div class="hero-pattern"></div>
    <div class="container">
      <div class="page-hero-content">
        <span class="tag">{t('nav.contact')}</span>
        <h1 class="section-title">{t('contact.hero.title')}</h1>
        <p class="section-desc">{t('contact.hero.desc')}</p>
      </div>
    </div>
  </section> -->

  <!-- CONTACT MAIN SECTION -->
  <section class="section contact-main-section">
    <div class="container">
      <div class="contact-grid">

        <!-- FORM -->
        <div class="contact-form-wrap">
          <div class="form-header">
            <h2 class="form-title">{t('contact.form.title')}</h2>
            <p class="form-subtitle">
              {lang === 'vi' ? 'Chúng tôi sẽ phản hồi trong vòng 24 giờ.' : lang === 'ko' ? '24시간 내에 답변 드리겠습니다.' : 'We will respond within 24 hours.'}
            </p>
          </div>

          <form class="contact-form" id="contactForm" novalidate>
            <div class="form-row">
              <div class="form-group">
                <label for="name">{t('contact.form.name')}</label>
                <input type="text" id="name" name="name" placeholder={lang === 'vi' ? 'Nguyễn Văn A' : lang === 'ko' ? '홍길동' : 'John Smith'} required />
              </div>
              <div class="form-group">
                <label for="email">{t('contact.form.email')}</label>
                <input type="email" id="email" name="email" placeholder="example@email.com" required />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="phone">{t('contact.form.phone')}</label>
                <input type="tel" id="phone" name="phone" placeholder="+84 xxx xxx xxxx" />
              </div>
              <div class="form-group">
                <label for="service">{t('contact.form.service')}</label>
                <select id="service" name="service">
                  <option value="">{t('contact.form.service')}</option>
                  <option value="cardiology">{t('services.cardiology.title')}</option>
                  <option value="neurology">{t('services.neurology.title')}</option>
                  <option value="pediatrics">{t('services.pediatrics.title')}</option>
                  <option value="orthopedics">{t('services.orthopedics.title')}</option>
                  <option value="dermatology">{t('services.dermatology.title')}</option>
                  <option value="oncology">{t('services.oncology.title')}</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="message">{t('contact.form.message')}</label>
              <textarea id="message" name="message" rows="5" placeholder={lang === 'vi' ? 'Mô tả tình trạng hoặc câu hỏi của bạn...' : lang === 'ko' ? '상태나 질문을 설명해 주세요...' : 'Describe your condition or question...'}></textarea>
            </div>

            <button type="submit" class="btn btn-primary btn-lg submit-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
              {t('contact.form.submit')}
            </button>

            <div class="form-success" id="formSuccess">
              ✅ {lang === 'vi' ? 'Tin nhắn đã được gửi thành công!' : lang === 'ko' ? '메시지가 성공적으로 전송되었습니다!' : 'Message sent successfully!'}
            </div>
          </form>
        </div>

        <!-- INFO -->
        <div class="contact-info-col">
          <h2 class="info-title">{t('contact.info.title')}</h2>

          <div class="info-cards">
            <!-- Address -->
            <div class="info-card">
              <div class="info-icon" style="background: rgba(10,110,110,0.12);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="#0A6E6E"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              </div>
              <div class="info-text">
                <span class="info-label">{t('contact.info.address')}</span>
                <a href="https://maps.app.goo.gl/cFbtSgpBnJPnscqt5">
                  <p class="info-value">{t('footer.address')}</p>
                </a>
              </div>
            </div>

            <!-- Phone -->
            <div class="info-card">
              <div class="info-icon" style="background: rgba(88, 166, 137, 0.122);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="#45B7D1"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              </div>
              <div class="info-text">
                <span class="info-label">{t('contact.info.phone')}</span>
                <a href=`tel:${t('footer.phone')}`>
                  <p class="info-value">{t('footer.phone')}</p>
                </a>
              </div>
            </div>

            <!-- Email -->
            <div class="info-card">
              <div class="info-icon" style="background: rgba(88, 166, 137, 0.122);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="#E8A020"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
              </div>
              <div class="info-text">
                <span class="info-label">{t('contact.info.email')}</span>
                <a href="mailto:scquangda@gmail.com">
                  <p class="info-value">scquangda@gmail.com</p>
                </a>
              </div>
            </div>

            <!-- Hours -->
            <div class="info-card">
              <div class="info-icon" style="background: rgba(88, 166, 137, 0.122);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="#6AAB8A"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
              </div>
              <div class="info-text">
                <span class="info-label">{t('contact.info.hours')}</span>
                <p class="info-value">{t('contact.hours.weekdays')}</p>
                <p class="info-value">{t('contact.hours.saturday')}</p>
                <p class="info-value emergency">{t('contact.hours.sunday')}</p>
              </div>
            </div>
          </div>

          <!-- zalo CTA -->
          <a href="https://zalo.me/84283456789" target="_blank" class="zalo-cta">
            <div class="wa-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><title>Zalo SVG Icon</title><path fill="currentColor" d="M12.49 10.272v-.45h1.347v6.322h-.77a.576.576 0 0 1-.577-.573v.001a3.27 3.27 0 0 1-1.938.632a3.284 3.284 0 0 1-3.284-3.282a3.284 3.284 0 0 1 3.284-3.282a3.27 3.27 0 0 1 1.937.632zM6.919 7.79v.205c0 .382-.051.694-.3 1.06l-.03.034a8 8 0 0 0-.242.285L2.024 14.8h4.895v.768a.576.576 0 0 1-.577.576H0v-.362c0-.443.11-.641.25-.847L4.858 9.23H.192V7.79zm8.551 8.354a.48.48 0 0 1-.48-.48V7.79h1.441v8.354zM20.693 9.6a3.306 3.306 0 1 1 .002 6.612a3.306 3.306 0 0 1-.002-6.612m-10.14 5.253a1.932 1.932 0 1 0 0-3.863a1.932 1.932 0 0 0 0 3.863m10.14-.003a1.945 1.945 0 1 0 0-3.89a1.945 1.945 0 0 0 0 3.89"/></svg>
            </div>
            <div>
              <strong>{lang === 'vi' ? 'Nhắn tin zalo' : lang === 'ko' ? 'zalo 채팅' : 'Chat on zalo'}</strong>
              <span>{lang === 'vi' ? 'Phản hồi nhanh 24/7' : lang === 'ko' ? '24/7 빠른 답변' : 'Quick response 24/7'}</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAP SECTION -->
  <section class="section map-section">
    <div class="container">
      <div class="section-header">
        <Flag title={t('contact.map.title')}/>
        <h2 class="section-title">{t('contact.map.title')}</h2>
      </div>
      <div class="map-wrap">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3836.0970726171927!2d108.25610139999999!3d15.956306299999998!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x314211003b54e251%3A0xa6b62ac7f436044d!2zUGjDsm5nIGtow6FtIGNodXnDqm4ga2hvYSBTQw!5e0!3m2!1ses!2sus!4v1773397913002!5m2!1ses!2sus" width="100%" height="420" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #f0f9f9 0%, #e8f4f8 100%);
    position: relative;
    overflow: hidden;
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 2px 2px, rgba(10,110,110,0.06) 1px, transparent 0);
    background-size: 36px 36px;
  }

  .page-hero-content { position: relative; z-index: 1; max-width: 600px; }

  /* CONTACT MAIN */
  .contact-main-section { background: white; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    align-items: start;
  }

  /* FORM */
  .form-header { margin-bottom: 32px; }

  .form-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 6px;
  }

  .form-subtitle { color: var(--text-muted); font-size: 0.9rem; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 0;
  }

  .form-group:not(.form-row .form-group) { margin-bottom: 20px; }

  .form-group label {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 0.825rem;
    color: var(--text);
    letter-spacing: 0.03em;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 12px 16px;
    border: 2px solid var(--border);
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--text);
    background: var(--bg);
    transition: border-color 0.2s ease;
    outline: none;
    resize: vertical;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--primary);
    background: white;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #A0AEC0;
  }

  .submit-btn {
    width: 100%;
    justify-content: center;
    margin-top: 8px;
  }

  .btn-lg { padding: 16px 32px; font-size: 1rem; }

  .form-success {
    display: none;
    background: #F0FFF4;
    color: #22543D;
    padding: 14px 18px;
    border-radius: 10px;
    margin-top: 16px;
    font-weight: 500;
    border: 1px solid #9AE6B4;
    font-size: 0.9rem;
  }

  .form-success.visible { display: block; }

  /* INFO */
  .info-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 24px;
  }

  .info-cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 28px;
  }

  .info-card {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 16px;
    background: var(--bg);
    border-radius: 12px;
    border: 1px solid var(--border);
    transition: all 0.2s ease;
  }

  .info-card:hover {
    border-color: var(--primary);
    background: rgba(10,110,110,0.03);
  }

  .info-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .info-label {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--primary);
    display: block;
    margin-bottom: 4px;
  }

  .info-value {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .info-value.emergency {
    color: #E53E3E;
    font-weight: 500;
  }

  /* zalo CTA */
  .zalo-cta {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 22px;
    background: linear-gradient(135deg, #255cd3, #1d49a8);
    border-radius: 14px;
    color: white;
    transition: all 0.25s ease;
    box-shadow: 0 6px 20px rgba(37, 127, 211, 0.3);
  }

  .zalo-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(37, 83, 211, 0.45);
  }

  .wa-icon {
    width: 48px;
    height: 48px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .zalo-cta strong {
    display: block;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    margin-bottom: 2px;
  }

  .zalo-cta span {
    font-size: 0.8rem;
    opacity: 0.85;
  }

  /* MAP */
  .map-section { background: var(--bg); }
  .section-header { margin-bottom: 40px; }

  .map-wrap {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--border);
  }

  @media (max-width: 1024px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
    .form-group:not(.form-row .form-group) { margin-bottom: 16px; }
  }
</style>

<script>
  const form = document.getElementById('contactForm');
  const successMsg = document.getElementById('formSuccess');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    successMsg?.classList.add('visible');
    setTimeout(() => {
      successMsg?.classList.remove('visible');
    }, 5000);
  });
</script>
