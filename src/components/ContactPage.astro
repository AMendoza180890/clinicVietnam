---
 import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/translations.js';

const { lang = 'vi' } = Astro.props;
const t = useTranslations(lang);
---

<Layout lang={lang} title={t('nav.contact')}>

  <!-- HERO -->
  <section class="page-hero section">
    <div class="hero-pattern"></div>
    <div class="container">
      <div class="page-hero-content">
        <span class="tag">{t('nav.contact')}</span>
        <h1 class="section-title">{t('contact.hero.title')}</h1>
        <p class="section-desc">{t('contact.hero.desc')}</p>
      </div>
    </div>
  </section>

  <!-- CONTACT MAIN SECTION -->
  <section class="section contact-main-section">
    <div class="container">
      <div class="contact-grid">

        <!-- FORM -->
        <div class="contact-form-wrap">
          <div class="form-header">
            <h2 class="form-title">{t('contact.form.title')}</h2>
            <p class="form-subtitle">
              {lang === 'vi' ? 'Chúng tôi sẽ phản hồi trong vòng 24 giờ.' : lang === 'ko' ? '24시간 내에 답변 드리겠습니다.' : 'We will respond within 24 hours.'}
            </p>
          </div>

          <form class="contact-form" id="contactForm" novalidate>
            <div class="form-row">
              <div class="form-group">
                <label for="name">{t('contact.form.name')}</label>
                <input type="text" id="name" name="name" placeholder={lang === 'vi' ? 'Nguyễn Văn A' : lang === 'ko' ? '홍길동' : 'John Smith'} required />
              </div>
              <div class="form-group">
                <label for="email">{t('contact.form.email')}</label>
                <input type="email" id="email" name="email" placeholder="example@email.com" required />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="phone">{t('contact.form.phone')}</label>
                <input type="tel" id="phone" name="phone" placeholder="+84 xxx xxx xxxx" />
              </div>
              <div class="form-group">
                <label for="service">{t('contact.form.service')}</label>
                <select id="service" name="service">
                  <option value="">{t('contact.form.service')}</option>
                  <option value="cardiology">{t('services.cardiology.title')}</option>
                  <option value="neurology">{t('services.neurology.title')}</option>
                  <option value="pediatrics">{t('services.pediatrics.title')}</option>
                  <option value="orthopedics">{t('services.orthopedics.title')}</option>
                  <option value="dermatology">{t('services.dermatology.title')}</option>
                  <option value="oncology">{t('services.oncology.title')}</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="message">{t('contact.form.message')}</label>
              <textarea id="message" name="message" rows="5" placeholder={lang === 'vi' ? 'Mô tả tình trạng hoặc câu hỏi của bạn...' : lang === 'ko' ? '상태나 질문을 설명해 주세요...' : 'Describe your condition or question...'}></textarea>
            </div>

            <button type="submit" class="btn btn-primary btn-lg submit-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
              {t('contact.form.submit')}
            </button>

            <div class="form-success" id="formSuccess">
              ✅ {lang === 'vi' ? 'Tin nhắn đã được gửi thành công!' : lang === 'ko' ? '메시지가 성공적으로 전송되었습니다!' : 'Message sent successfully!'}
            </div>
          </form>
        </div>

        <!-- INFO -->
        <div class="contact-info-col">
          <h2 class="info-title">{t('contact.info.title')}</h2>

          <div class="info-cards">
            <!-- Address -->
            <div class="info-card">
              <div class="info-icon" style="background: rgba(10,110,110,0.12);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="#0A6E6E"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              </div>
              <div class="info-text">
                <span class="info-label">{t('contact.info.address')}</span>
                <p class="info-value">{t('footer.address')}</p>
              </div>
            </div>

            <!-- Phone -->
            <div class="info-card">
              <div class="info-icon" style="background: rgba(69,183,209,0.12);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="#45B7D1"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              </div>
              <div class="info-text">
                <span class="info-label">{t('contact.info.phone')}</span>
                <p class="info-value">{t('footer.phone')}</p>
              </div>
            </div>

            <!-- Email -->
            <div class="info-card">
              <div class="info-icon" style="background: rgba(232,160,32,0.12);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="#E8A020"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
              </div>
              <div class="info-text">
                <span class="info-label">{t('contact.info.email')}</span>
                <p class="info-value">info@medicare-clinic.com</p>
              </div>
            </div>

            <!-- Hours -->
            <div class="info-card">
              <div class="info-icon" style="background: rgba(150,206,180,0.2);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="#6AAB8A"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
              </div>
              <div class="info-text">
                <span class="info-label">{t('contact.info.hours')}</span>
                <p class="info-value">{t('contact.hours.weekdays')}</p>
                <p class="info-value">{t('contact.hours.saturday')}</p>
                <p class="info-value emergency">{t('contact.hours.sunday')}</p>
              </div>
            </div>
          </div>

          <!-- WhatsApp CTA -->
          <a href="https://wa.me/84283456789" target="_blank" class="whatsapp-cta">
            <div class="wa-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            </div>
            <div>
              <strong>{lang === 'vi' ? 'Nhắn tin WhatsApp' : lang === 'ko' ? 'WhatsApp 채팅' : 'Chat on WhatsApp'}</strong>
              <span>{lang === 'vi' ? 'Phản hồi nhanh 24/7' : lang === 'ko' ? '24/7 빠른 답변' : 'Quick response 24/7'}</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAP SECTION -->
  <section class="section map-section">
    <div class="container">
      <div class="section-header">
        <span class="tag">{t('contact.map.title')}</span>
        <h2 class="section-title">{t('contact.map.title')}</h2>
      </div>
      <div class="map-wrap">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.4535786028264!2d106.69756717480764!3d10.776889789374765!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f4b3330bcc7%3A0x4db964d76bf6e18e!2sDistrict%201%2C%20Ho%20Chi%20Minh%20City!5e0!3m2!1sen!2svn!4v1706000000000!5m2!1sen!2svn"
          width="100%"
          height="420"
          style="border:0; border-radius: 16px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #f0f9f9 0%, #e8f4f8 100%);
    position: relative;
    overflow: hidden;
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 2px 2px, rgba(10,110,110,0.06) 1px, transparent 0);
    background-size: 36px 36px;
  }

  .page-hero-content { position: relative; z-index: 1; max-width: 600px; }

  /* CONTACT MAIN */
  .contact-main-section { background: white; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    align-items: start;
  }

  /* FORM */
  .form-header { margin-bottom: 32px; }

  .form-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 6px;
  }

  .form-subtitle { color: var(--text-muted); font-size: 0.9rem; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 0;
  }

  .form-group:not(.form-row .form-group) { margin-bottom: 20px; }

  .form-group label {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 0.825rem;
    color: var(--text);
    letter-spacing: 0.03em;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 12px 16px;
    border: 2px solid var(--border);
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--text);
    background: var(--bg);
    transition: border-color 0.2s ease;
    outline: none;
    resize: vertical;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--primary);
    background: white;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #A0AEC0;
  }

  .submit-btn {
    width: 100%;
    justify-content: center;
    margin-top: 8px;
  }

  .btn-lg { padding: 16px 32px; font-size: 1rem; }

  .form-success {
    display: none;
    background: #F0FFF4;
    color: #22543D;
    padding: 14px 18px;
    border-radius: 10px;
    margin-top: 16px;
    font-weight: 500;
    border: 1px solid #9AE6B4;
    font-size: 0.9rem;
  }

  .form-success.visible { display: block; }

  /* INFO */
  .info-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 24px;
  }

  .info-cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 28px;
  }

  .info-card {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 16px;
    background: var(--bg);
    border-radius: 12px;
    border: 1px solid var(--border);
    transition: all 0.2s ease;
  }

  .info-card:hover {
    border-color: var(--primary);
    background: rgba(10,110,110,0.03);
  }

  .info-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .info-label {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--primary);
    display: block;
    margin-bottom: 4px;
  }

  .info-value {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .info-value.emergency {
    color: #E53E3E;
    font-weight: 500;
  }

  /* WHATSAPP CTA */
  .whatsapp-cta {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 22px;
    background: linear-gradient(135deg, #25D366, #1DA851);
    border-radius: 14px;
    color: white;
    transition: all 0.25s ease;
    box-shadow: 0 6px 20px rgba(37,211,102,0.3);
  }

  .whatsapp-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(37,211,102,0.45);
  }

  .wa-icon {
    width: 48px;
    height: 48px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .whatsapp-cta strong {
    display: block;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    margin-bottom: 2px;
  }

  .whatsapp-cta span {
    font-size: 0.8rem;
    opacity: 0.85;
  }

  /* MAP */
  .map-section { background: var(--bg); }
  .section-header { margin-bottom: 40px; }

  .map-wrap {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--border);
  }

  @media (max-width: 1024px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
    .form-group:not(.form-row .form-group) { margin-bottom: 16px; }
  }
</style>

<script>
  const form = document.getElementById('contactForm');
  const successMsg = document.getElementById('formSuccess');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    successMsg?.classList.add('visible');
    form.reset();
    setTimeout(() => {
      successMsg?.classList.remove('visible');
    }, 5000);
  });
</script>
